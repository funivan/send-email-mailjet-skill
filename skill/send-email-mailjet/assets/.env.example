# Example environment file for send-email-mailjet-skill
# Copy this file to `.env` and fill in real values.

# Required
## https://app.mailjet.com/account/apikeys
MJ_APIKEY_PUBLIC=your_mailjet_public_key_here
MJ_APIKEY_PRIVATE=your_mailjet_private_key_here

# Optional

# override the Mailjet API endpoint (default used by the script)
# MJ_API_URL=https://api.mailjet.com/v3.1/send

# Email fields (optional)
MAIL_FROM=sender@example.com
MAIL_TO=recipient@example.com
MAIL_SUBJECT=Test email
MAIL_BODY=Hello from AI

# Attachments: MAIL_FILES_1, MAIL_FILES_2, ...
#MAIL_FILES_1=path/to/attachment1.pdf
#MAIL_FILES_2=path/to/attachment2.png
